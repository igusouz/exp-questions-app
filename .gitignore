# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typing
*.d.ts
*.tsbuildinfo
next-env.d.ts

# IDE and Editor files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
.project
.classpath
.c9/
*.launch
.settings/
*.swp
*.swo
*~
.tern-port

# OS-specific files
Thumbs.db
.Spotlight-V100
.Trashes
ehthumbs.db
.AppleDouble
.LSOverride

# Lock files (if using npm, include package-lock.json)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# Build artifacts
dist/
build/
.turbo/
.cache/

# Logs
lerna-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local development
.env.local
.env.*.local
